package components

import "routex/i18n"

templ SearchBar(loc *i18n.Localizer) {
	<div style="margin-bottom:1rem">
		<input
			type="text"
			name="q"
			placeholder={ loc.T("search.placeholder") }
			style="width:100%"
			hx-get="/htmx/groups/search"
			hx-trigger="input changed delay:300ms, search"
			hx-target="#groups-content"
			hx-swap="innerHTML"
			hx-indicator="#search-spinner"
		/>
		<span id="search-spinner" class="htmx-indicator spinner" style="margin-left:0.5rem"></span>
	</div>
}
